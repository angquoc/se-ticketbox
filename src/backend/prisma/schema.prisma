generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ORGANIZER
  CHECKIN_STAFF
  ADMIN
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  SALE_OPEN
  SALE_CLOSED
  CANCELLED
  COMPLETED
}

// Indicates the availability state of a ticket type.
enum TicketTypeStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

// Tracks the lifecycle of a customer order.
enum OrderStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  FAILED
  REFUNDED
}

// Identifies the third-party payment gateway used.
enum PaymentProvider {
  MOMO
  VNPAY
  MOCK
}

// Reflects the outcome of a payment transaction.
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELLED
}

// Tracks the usage state of an individual ticket.
enum TicketStatus {
  ACTIVE
  CHECKED_IN
  CANCELLED
  REFUNDED
}

// Indicates the state of a ticket reservation hold.
enum ReservationStatus {
  ACTIVE
  RELEASED
  CONVERTED
  EXPIRED
}

// Tracks the processing state of an idempotency key.
enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// Describes the result of a ticket check-in attempt.
enum CheckinStatus {
  SUCCESS
  INVALID_TICKET
  ALREADY_CHECKED_IN
  OFFLINE_PENDING
  REJECTED_CONFLICT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  fullName     String?
  role         UserRole @default(CUSTOMER)

  orders              Order[]
  tickets             Ticket[]
  reservations        TicketReservation[]
  idempotencyKeys     IdempotencyKey[]
  ticketCounters      UserTicketCounter[]
  createdConcerts     Concert[] @relation("ConcertCreator")
  checkinLogsAsStaff  CheckinLog[] @relation("StaffCheckins")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Concert {
  id            String        @id @default(uuid())
  slug          String        @unique
  name          String
  description   String?
  artistName    String?
  venue         String
  startsAt      DateTime
  saleStartsAt  DateTime
  saleEndsAt    DateTime
  status        ConcertStatus @default(DRAFT)

  seatMapSvgUrl String?
  artistBio     String?

  createdById String?
  createdBy   User? @relation("ConcertCreator", fields: [createdById], references: [id])

  ticketTypes      TicketType[]
  tickets          Ticket[]
  checkinLogs      CheckinLog[]
  guestListEntries GuestListEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt])
  @@index([saleStartsAt, saleEndsAt])
}

model TicketType {
  id        String  @id @default(uuid())
  concertId String
  concert   Concert @relation(fields: [concertId], references: [id])

  code String
  name String

  priceVnd      Int
  totalQuantity Int

  /*
    soldQuantity: number of tickets that have been successfully paid.
    reservedQuantity: number of tickets currently held under temporary reservation.
    For high-concurrency scenarios, Redis handles atomic reserve operations.
    These fields store durable state and are used for reporting.
  */
  soldQuantity     Int @default(0)
  reservedQuantity Int @default(0)

  maxPerUser Int

  saleStartsAt DateTime?
  saleEndsAt   DateTime?

  status TicketTypeStatus @default(ACTIVE)

  orderItems      OrderItem[]
  tickets         Ticket[]
  reservations    TicketReservation[]
  userCounters    UserTicketCounter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([concertId, code])
  @@index([concertId, status])
}

model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  status         OrderStatus @default(PENDIN)
  totalAmountVnd Int
  currency       String      @default("VND")

  paymentProvider PaymentProvider?
  paymentRef      String? @unique

  expiresAt   DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  items        OrderItem[]
  tickets      Ticket[]
  payments     PaymentTransaction[]
  reservation  TicketReservation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, expiresAt])
}

model OrderItem {
  id           String @id @default(uuid())
  orderId      String
  ticketTypeId String

  order      Order      @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  quantity     Int
  unitPriceVnd Int
  subtotalVnd  Int

  tickets Ticket[]

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([ticketTypeId])
}

model TicketReservation {
  id           String @id @default(uuid())
  orderId      String @unique
  userId       String
  ticketTypeId String

  order      Order      @relation(fields: [orderId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  quantity Int
  status   ReservationStatus @default(ACTIVE)

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([userId, ticketTypeId, status])
}

model Ticket {
  id           String @id @default(uuid())
  orderId      String
  orderItemId  String?
  concertId    String
  ticketTypeId String
  userId       String

  order      Order       @relation(fields: [orderId], references: [id])
  orderItem  OrderItem?  @relation(fields: [orderItemId], references: [id])
  concert    Concert     @relation(fields: [concertId], references: [id])
  ticketType TicketType  @relation(fields: [ticketTypeId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  /*
    Store only the hash of the QR token, never the raw token.
    This ensures that even if the database is compromised, the real QR codes remain secure.
  */
  qrTokenHash String @unique

  status      TicketStatus @default(ACTIVE)
  checkedInAt DateTime?

  checkinLogs CheckinLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([concertId, status])
  @@index([ticketTypeId, status])
}

model PaymentTransaction {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  provider PaymentProvider

  /*
    Transaction ID returned by the MoMo/VNPAY/mock gateway.
    Used to ensure callbacks are not processed multiple times.
  */
  providerTransactionId String?

  amountVnd Int
  status    PaymentStatus

  rawPayload Json?

  receivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([provider, providerTransactionId])
  @@index([orderId, status])
}

model IdempotencyKey {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  key         String
  requestHash String

  /*
    Example:
    resourceType = "ORDER"
    resourceId = orderId
  */
  resourceType String?
  resourceId   String?

  status IdempotencyStatus @default(PROCESSING)

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([expiresAt])
}

model UserTicketCounter {
  userId       String
  ticketTypeId String

  user       User       @relation(fields: [userId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  /*
    Used to enforce max_per_user in a durable manner.
    Redis Lua scripts use a high-speed counter for real-time enforcement.
    This DB counter is used for auditing and rebuilding Redis state if needed.
  */
  paidQuantity     Int @default(0)
  reservedQuantity Int @default(0)

  updatedAt DateTime @updatedAt

  @@id([userId, ticketTypeId])
}

model CheckinLog {
  id        String @id @default(uuid())
  ticketId  String?
  staffId   String?
  concertId String?

  ticket  Ticket?  @relation(fields: [ticketId], references: [id])
  staff   User?    @relation("StaffCheckins", fields: [staffId], references: [id])
  concert Concert? @relation(fields: [concertId], references: [id])

  gate     String?
  deviceId String

  /*
    Used when the mobile app performs offline check-in.
    When syncing back, the device sends offlineEventId so the backend can process it idempotently.
  */
  offlineEventId String?

  status CheckinStatus
  reason String?

  scannedAt DateTime
  syncedAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([deviceId, offlineEventId])
  @@index([ticketId, scannedAt])
  @@index([staffId, scannedAt])
  @@index([concertId, scannedAt])
}

model GuestListEntry {
  id        String @id @default(uuid())
  concertId String
  concert   Concert @relation(fields: [concertId], references: [id])

  fullName String
  email    String?
  phone    String?
  company  String?

  ticketLabel String?
  sourceFile  String?

  checkedInAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([concertId])
  @@index([email])
  @@index([phone])
}