# URL Backend API (NestJS)
BACKEND_API_URL=http://localhost:3001

# Không bắt buộc — frontend dùng UUID concert trực tiếp từ backend.
# Chỉ cần khi muốn map id demo cũ sang UUID backend:
# BACKEND_CONCERT_MAP={"demo-concert":"<uuid>","concert-001":"<uuid>"}

# Virtual Waiting Room (mock) — chỉ bật khi tải vượt ngưỡng (design: 80k req / 5 phút)
# WAITING_ROOM_JOIN_THRESHOLD=12
# FORCE_WAITING_ROOM=true
